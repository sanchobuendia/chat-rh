[run]
source = app
omit =
    app/__init__.py
    app/api/__init__.py
    app/core/__init__.py
    app/db/__init__.py
    app/graph/__init__.py
    app/models/__init__.py
    app/repositories/__init__.py
    app/schemas/__init__.py
    app/services/__init__.py
    app/workers/__init__.py

[report]
skip_covered = False
show_missing = True
